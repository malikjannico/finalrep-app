# FinalRep App - Environment Variables Template
# Copy this file to your local development folders (app root or backend root) and fill in the values.

# ==========================================
# 1. FLUTTER FRONTEND CONFIGURATION
# ==========================================
# These variables are compiled into the Flutter App via --dart-define-from-file or environment definitions.

ENV=dev
API_BASE_URL=http://localhost:8080

# Firebase Auth Configuration (Identity Platform)
FIREBASE_API_KEY=AIzaSyFakeKeyStaging1234567890
FIREBASE_AUTH_DOMAIN=finalrep-app.firebaseapp.com
FIREBASE_PROJECT_ID=finalrep-app
FIREBASE_STORAGE_BUCKET=finalrep-app-media-staging
FIREBASE_MESSAGING_SENDER_ID=775534547890
FIREBASE_APP_ID=1:775534547890:web:staging1234567890


# ==========================================
# 2. DART FROG BACKEND API GATEWAY CONFIGURATION
# ==========================================
# These variables configure the backend container running on Cloud Run or locally.

# Database Connection (TCP locally, or Unix Sockets in Cloud Run)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finalrep_db
DB_USER=app_user
DB_PASS=app_dev_db_password

# For Cloud Run UNIX Socket Connection (e.g. /cloudsql/project:region:instance)
DB_SOCKET_PATH=

# Google Cloud Storage Upload Bucket
STORAGE_BUCKET_NAME=finalrep-app-media-dev
